{
    "http": {
        "middlewares": {
            "heartbeatmiddleware": {
                "plugin": {
                    "heartbeatmiddleware": {
                        "reportEndpoint": "https://garnix.io/api/hosts/heartbeat"
                    }
                }
            }
        },
        "routers": {
            "package.branch.repo.user": {
                "middlewares": [
                    "heartbeatmiddleware"
                ],
                "rule": "Host(`package.branch.repo.user.garnix.me`)",
                "service": "package.branch.repo.user"
            }
        },
        "services": {
            "package.branch.repo.user": {
                "loadBalancer": {
                    "servers": [
                        {
                            "url": "http://11.111.111.2"
                        }
                    ]
                }
            }
        }
    }
}