{
    "http": {
        "middlewares": {
            "heartbeatmiddleware": {
                "plugin": {
                    "heartbeatmiddleware": {
                        "reportEndpoint": "https://garnix.io/api/hosts/heartbeat"
                    }
                }
            }
        },
        "routers": {
            "nginx.pull-42.repo.owner": {
                "middlewares": [
                    "heartbeatmiddleware"
                ],
                "rule": "Host(`nginx.pull-42.repo.owner.garnix.me`)",
                "service": "nginx.pull-42.repo.owner"
            }
        },
        "services": {
            "nginx.pull-42.repo.owner": {
                "loadBalancer": {
                    "servers": [
                        {
                            "url": "http://11.111.111.1"
                        }
                    ]
                }
            }
        }
    }
}