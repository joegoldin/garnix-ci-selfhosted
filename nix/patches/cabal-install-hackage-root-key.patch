--- a/src/Distribution/Client/Security/DNS.hs
+++ b/src/Distribution/Client/Security/DNS.hs
@@ -74,6 +74,7 @@ queryBootstrapMirrors verbosity repoUri
 -- | Extract list of mirrors from 'queryTXT' result
 extractMirrors :: [[CharStr]] -> [URI]
-extractMirrors txtChunks = mapMaybe (parseURI . snd) . sort $ vals
+extractMirrors txtChunks =
+  excludeRetiredMirrors . mapMaybe (parseURI . snd) . sort $ vals
   where
     vals = [ (kn,v) | CharStr e <- concat txtChunks
                     , Just (k,v) <- [splitRfc1464 (BS.Char8.unpack e)]
@@ -123,6 +124,7 @@ queryBootstrapMirrors verbosity repoUri
 -- | Extract list of mirrors from @nslookup -query=TXT@ output.
 extractMirrors :: String -> String -> [URI]
-extractMirrors hostname s0 = mapMaybe (parseURI . snd) . sort $ vals
+extractMirrors hostname s0 =
+  excludeRetiredMirrors . mapMaybe (parseURI . snd) . sort $ vals
   where
     vals = [ (kn,v) | (h,ents) <- fromMaybe [] $ parseNsLookupTxt s0
                     , h == hostname
@@ -165,6 +167,12 @@ parseNsLookupTxt = go0 [] []
 #endif
 ----------------------------------------------------------------------------
-
+-- DreamHost retired this Hackage mirror, but it remains in Hackage's DNS
+-- bootstrap record. Do not waste a fallback attempt on the dead endpoint.
+excludeRetiredMirrors :: [URI] -> [URI]
+excludeRetiredMirrors = filter $ \uri -> case uriAuthority uri of
+  Just auth -> uriRegName auth /= "objects-us-east-1.dream.io"
+  Nothing -> True
+
 -- | Helper used by 'extractMirrors' for extracting @urlbase@ keys from Rfc1464-encoded data
 isUrlBase :: String -> Maybe Int
 isUrlBase s
